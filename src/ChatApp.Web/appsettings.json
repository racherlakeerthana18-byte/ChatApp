{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Chat": {
    "RoomCodeLength": 6,
    "RoomTtlHours": 24,
    "MessageTtlHours": 24,
    "PresenceTtlSeconds": 60,
    "TypingTtlSeconds": 10,
    "MinNicknameLength": 2,
    "MaxNicknameLength": 24,
    "MinRoomNameLength": 3,
    "MaxRoomNameLength": 40,
    "MaxMessageLength": 500,
    "MaxRoomParticipants": 100,
    "MaxMessageHistory": 200,
    "ListedRoomLimit": 100,
    "CreateRoomLimitPerMinute": 6,
    "MessageLimitPerTenSeconds": 8,
    "ReportLimitPerMinute": 10,
    "AdminPasscode": "change-me",
    "AdminCookieName": "chatapp-admin",
    "AdminCookieSecret": "chatapp-admin-cookie",
    "BannedTerms": [
      "blockedword"
    ]
  },
  "TemporaryStore": {
    "Provider": "InMemory",
    "KeyPrefix": "chatapp"
  },
  "ConnectionStrings": {
    "Redis": ""
  },
  "AllowedHosts": "*"
}
