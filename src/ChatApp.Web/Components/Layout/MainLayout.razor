@inherits LayoutComponentBase

<div class="shell">
    <header class="topbar">
        <NavLink class="brand-mark" href="/" Match="NavLinkMatch.All">EchoDrop</NavLink>
        <nav class="topbar-links">
            <NavLink class="topbar-link" href="/" Match="NavLinkMatch.All">Rooms</NavLink>
            <NavLink class="topbar-link" href="/admin">Admin</NavLink>
            <a class="topbar-link" href="/health" target="_blank" rel="noreferrer">Health</a>
        </nav>
    </header>

    <main class="shell-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
